{
    "model": "tmp/sft/0.6B_small",
    "training_file": "../data/code_train_small.jsonl",
    "test_file": "../data/code_eval_small.jsonl",
    "finetuned_model_id": "grpo/0_6B_small",
    "max_seq_length": 2048,
    "load_in_4bit": false,
    "loss": "sft",
    "is_peft": true,
    "target_modules": [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj",
        "gate_proj",
        "up_proj",
        "down_proj"
    ],
    "lora_bias": "none",
    "r": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "use_rslora": true,
    "merge_before_push": true,
    "push_to_private": true,
    "epochs": 1,
    "max_steps": null,
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "warmup_steps": 5,
    "learning_rate": 5e-4,
    "logging_steps": 5,
    "optim": "adamw_8bit",
    "weight_decay": 0.001,
    "lr_scheduler_type": "linear",
    "seed": 0,
    "beta": 0.1,
    "save_steps": 5000,
    "output_dir": "./tmp",
    "train_on_responses_only": true,
    "reward_model": "gpt-4.1-nano",
    "grader_type": "code_incorrect",
    "reward_coherence": false,
    "rl_kl_weight": 0.1,
    "rl_rollout_batch_size": 8,
    "rl_max_new_tokens": 500,
    "rl_temperature": 1.0,
    "rl_top_p": 1.0
}